  "statisticalCoefficients": {
    "_comment": "Applied by meta_weights.py when building brawler_intelligence, and by the engine as score multipliers. true_win_rate = Bayesian shrink of raw WR toward 50% with confidencePriorGames of prior weight, so tiny samples can't fake a 60% brawler.",
    "confidencePriorGames": 30,
    "pairMinPicks": 20,
    "recency": {
      "_comment": "Dual-window drift detection: brawler_intelligence carries recent_* stats over the last windowDays (computed from collected_at). When the recent sample is solid, the engine blends recent WR at recentWeight over the full-patch rate — so a shadow nerf shows up in suggestions within days, no matter how many older games say otherwise. trendDeltaPct is the recent-vs-overall gap that surfaces a trending chip.",
      "windowDays": 14,
      "minRecentPicks": 300,
      "recentWeight": 0.6,
      "trendDeltaPct": 4,
      "downLabel": "Trending down",
      "upLabel": "Trending up"
    },
    "popularityTrap": { "minPickRatePct": 20, "maxWinRatePct": 48, "scoreMultiplier": 0.85, "label": "Popularity trap" },
    "brokenIndicator": { "minPickRatePct": 10, "minWinRatePct": 52, "scoreMultiplier": 1.12, "label": "Meta breaker" },
    "inflationBias": { "maxPickRatePct": 3, "minWinRatePct": 55, "scoreMultiplier": 0.9, "label": "Inflated WR" }
  },

  "constraints": {
    "throwerPenalty": {
      "_comment": "Bobby: 'never pick a thrower unless it's last pick or you have protection for it'. Flat penalty on global pick slots 1-4, waived if the team already fields a protection class, halved in passive-tempo modes where throwers are structurally strong.",
      "appliesToPickSlots": [1, 2, 3, 4],
      "penalty": -50,
      "waivedWithProtection": true,
      "protectionClasses": ["TANK", "CONTROL"],
      "passiveTempoMultiplier": 0.5
    },
    "classDiversity": {
      "_comment": "Bobby: 'if you pick three control brawlers, all of your brawlers are countered by one aggro'. Multiplier per duplicate class already on the team (compounds: 0.7, then 0.49).",
      "duplicateMultiplier": 0.7
    },
    "antiTankFirstPick": {
      "_comment": "Bobby: 'anti-tank is the foundation of every draft'; best anti-tank is almost always the correct first pick in objective (active) modes.",
      "bonus": 12,
      "appliesToPickSlots": [1, 2],
      "activeTempoOnly": true
    },
    "spaceMakerLateBonus": {
      "_comment": "Space makers are the skill separator — strongest in slots 4-6 when the enemy comp is revealed and can't answer the dive.",
      "bonus": 8,
      "appliesToPickSlots": [4, 5, 6],
      "requiresEnemyCommitted": true
    },
    "counterStack": {
      "_comment": "Bobby: 'if the enemy commits to a class, the hard counter to it is almost a free pick'. When the enemy fields 2+ of one class, a brawler whose class hard-counters it (counterMatrix >= hardCounterThreshold) gets a flat bonus PER stacked enemy — applied AFTER mode weighting so a favorable enemy mode can't bury the counter (e.g. two snipers on a Bounty map still make Mortis/Kit a lock).",
      "minStack": 2,
      "hardCounterThreshold": 1.5,
      "bonusPerEnemy": 9
    }
  },

  "abilityRules": {
    "_comment": "Ability-tag synergy/counter rules (Bobby): wall break opens lanes for snipers, strips the cover throwers depend on, and forces anti-tanks into the open where snipers kite them. Applied on top of the class counter matrix; bonuses are on the same ~50-point score scale as the other constraints.",
    "wallBreakSniperSynergy": { "bonusPerSniper": 4, "label": "Opens sniper lanes" },
    "wallBreakVsThrower": { "bonusPerThrower": 7, "label": "Breaks thrower cover" },
    "wallBreakSniperVsAntiTank": { "bonus": 4, "label": "Forces anti-tank open" },
    "sniperWithWallBreakSynergy": { "bonus": 3, "label": "Lanes already open" }
  },

  "supportRules": {
    "_comment": "Bobby: supports are reactive 'conditional modifiers'. Never draft one in the first two global picks unless it's a meta-anchor on this map (waiver: map true WR >= waiverMinMapTrueWR); never without a lane/aggro partner to support. Named combos reward the known pairings late-draft.",
    "earlyPickPenalty": { "appliesToPickSlots": [1, 2], "penalty": -10, "waiverMinMapTrueWR": 53, "label": "Support too early" },
    "needsPartnerClasses": ["TANK", "SPACE_MAKER", "SNIPER", "ANTI_TANK"],
    "noPartnerPenalty": -6,
    "noPartnerLabel": "No lane to support",
    "combos": [
      { "brawler": "GRAY", "teammateClasses": ["TANK"], "modes": ["hotZone"], "bonus": 6, "label": "Gray + tank combo" },
      { "brawler": "KIT", "teammateClasses": ["TANK", "SPACE_MAKER"], "modes": ["knockout"], "bonus": 6, "label": "Kit ride-along" },
      { "brawler": "MAX", "enemyClasses": ["SNIPER"], "tempo": "passive", "bonus": 5, "label": "Runs down snipers" },
      { "brawler": "MAX", "modes": ["brawlBall"], "bonus": 3, "label": "Tempo engine" }
    ]
  },

  "counterLadder": {
    "_comment": "Phase-specific drafting: picks 1-2 are the anchor phase (stats-led, counters barely matter — the enemy hasn't committed), 3-4 target revealed picks, 5-6 are hard-counter execution. counterWeightBySlot scales BOTH the class-matrix and empirical vs-class edges. Preventative blocking (PASS 3) is naturally off at slot 6 since the enemy comp is complete. lastPickSpecialist: a brawler with a thin map sample is a niche/last-pick option, demoted during slots 1-4. throwerLastPick: at slots 5-6 a thrower gets a bonus when the enemy fielded no wall break to strip its cover.",
    "counterWeightBySlot": { "1": 0.8, "2": 0.9, "3": 1.0, "4": 1.1, "5": 1.15, "6": 1.3 },
    "lastPickSpecialist": { "minMapPicks": 50, "appliesToPickSlots": [1, 2, 3, 4], "multiplier": 0.85 },
    "throwerLastPick": { "minSlot": 5, "requiresEnemyNoWallBreak": true, "bonus": 5, "label": "Thrower window" },
    "denial": {
      "_comment": "Interception drafting: the engine evaluates the ENEMY's theoretical best next pick; if that brawler also scores well for us, stealing it denies their plan.",
      "scoreMultiplier": 1.1,
      "label": "Denies their pick"
    }
  },

