  "counterMatrix": {
    "_comment": "counterMatrix[A][B] > 0 means class A counters class B (score -2..+2). Encodes Bobby's triangle: Anti-Tank beats Tank, Tank/Aggro beats Control, Control beats Anti-Tank — 'everything in the game gets countered by something'. Space makers dive backline (snipers/throwers/support) but die to anti-tank damage and control.",
    "ANTI_TANK":   { "ANTI_TANK": 0,    "TANK": 2,    "SPACE_MAKER": 1.5,  "CONTROL": -1.5, "THROWER": -1,   "SNIPER": -0.5, "SUPPORT": 0.5 },
    "TANK":        { "ANTI_TANK": -2,   "TANK": 0,    "SPACE_MAKER": 0.5,  "CONTROL": 1.5,  "THROWER": -1.5, "SNIPER": -1,   "SUPPORT": 1 },
    "SPACE_MAKER": { "ANTI_TANK": -1.5, "TANK": -0.5, "SPACE_MAKER": 0,    "CONTROL": -1,   "THROWER": 1.5,  "SNIPER": 2,    "SUPPORT": 1.5 },
    "CONTROL":     { "ANTI_TANK": 1.5,  "TANK": -1.5, "SPACE_MAKER": 1,    "CONTROL": 0,    "THROWER": -0.5, "SNIPER": -1,   "SUPPORT": 0.5 },
    "THROWER":     { "ANTI_TANK": 1,    "TANK": 1.5,  "SPACE_MAKER": -1.5, "CONTROL": 0.5,  "THROWER": 0,    "SNIPER": -1.5, "SUPPORT": 0 },
    "SNIPER":      { "ANTI_TANK": 0.5,  "TANK": 1,    "SPACE_MAKER": -2,   "CONTROL": 1,    "THROWER": 1.5,  "SNIPER": 0,    "SUPPORT": 1 },
    "SUPPORT":     { "ANTI_TANK": -0.5, "TANK": -1,   "SPACE_MAKER": -1.5, "CONTROL": -0.5, "THROWER": 0,    "SNIPER": -1,   "SUPPORT": 0 }
  },

  "matchupOverrides": {
    "_comment": "Per-brawler exceptions to the class counter matrix. Value = the LISTED brawler's edge (-2..+2) against that enemy class, replacing its class default in BOTH directions (the reverse pairing uses the negation). BOLT: THROWER 0 → Bolt is a tank but mobile enough that throwers don't counter him — no 'Weak vs' penalty for Bolt against throwers, and no 'Counters Bolt' credit for throwers.",
    "BOLT": { "THROWER": 0 }
  },

  "synergyPairs": {
    "_comment": "Same-team class pairings that amplify each other. Applied once per pair present in a comp.",
    "TANK+SUPPORT": 1.5,
    "TANK+CONTROL": 1,
    "THROWER+TANK": 1.5,
    "THROWER+CONTROL": 1,
    "SPACE_MAKER+SNIPER": 1,
    "SPACE_MAKER+SUPPORT": 0.5,
    "ANTI_TANK+CONTROL": 0.5,
    "ANTI_TANK+SUPPORT": 0.5
  },

