  "attributeRules": {
    "_comment": "Mechanical interaction rules from the draft doc, magnitudes retuned to this engine's ~50-point score scale (the doc's raw ±15-20% would swamp real win-rate edges, where 5% WR = 2.5 pts). Geometry modifiers are DAMPENED by dampWithMapData when the brawler has a solid map sample — the live map WR already encodes how the map treats them, so the static prior mainly fills in when data is thin.",
    "singleShotVsSpawner": {
      "_comment": "High-damage single instances get eaten by attackable summons. Waived when a teammate brings PIERCE/SPLASH wave-clear.",
      "scoreMultiplier": 0.88,
      "waivedByTeammateAttackTypes": ["PIERCE", "SPLASH"],
      "label": "Summon fodder"
    },
    "clearsSummons": {
      "_comment": "Pierce/splash clears summons while still hitting the primary target.",
      "attackTypeBonus": { "PIERCE": 5, "SPLASH": 3 },
      "label": "Clears summons"
    },
    "geometry": {
      "_comment": "wallBreakShiftsOpen: a friendly wall breaker physically opens the map mid-game — CLOSED evaluates as MIXED, MIXED as OPEN (dynamic map mutation).",
      "OPEN":   { "rangeMultipliers": { "Long": 1.1, "Short": 0.85 } },
      "CLOSED": { "rangeMultipliers": { "Short": 1.1, "Long": 0.88 }, "classMultipliers": { "THROWER": 1.08 } },
      "MIXED":  { "rangeMultipliers": {} },
      "dampWithMapData": 0.5,
      "wallBreakShiftsOpen": true
    },
    "bushSynergy": { "HIGH": 4, "MEDIUM": 2, "label": "Bush lurker" },
    "wallBreakOwnThrower": {
      "_comment": "Anti-synergy: a friendly wall breaker destroys the cover the team's own thrower depends on. Applied in both directions (wall breaker joining a thrower comp, or thrower joining a wall-break comp). Exempt in Heist, where breaking the safe lane open is the whole point.",
      "scoreMultiplier": 0.92,
      "exemptModes": ["heist"],
      "label": "Breaks own cover"
    },
    "scalerSaturation": {
      "_comment": "Two late-game scaling kits on one team concede the early map. Applies to brawlers flagged scaler in brawlerAttributes.",
      "scoreMultiplier": 0.85,
      "label": "Second scaler"
    },
    "utilitySaturation": {
      "_comment": "In DPS-hungry objective modes, a third pick from the utility classes loses the damage race (mode classWeights already discourage one; this catches the mixed-class trio the duplicate penalty misses).",
      "modes": ["heist", "hotZone"],
      "classes": ["SUPPORT", "THROWER", "CONTROL"],
      "maxUtility": 2,
      "scoreMultiplier": 0.75,
      "label": "Third utility pick"
    }
  },

  "winProbability": {
    "_comment": "Draft-complete win split. Logistic squash of the comp-score differential; capped 85/15 because no draft is ever truly 90-10 — execution still exists.",
    "logisticScale": 14,
    "capPct": 85
  }
}
